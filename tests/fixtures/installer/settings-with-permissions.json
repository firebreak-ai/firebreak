{
  "permissions": {
    "allow": ["Read", "Glob"],
    "deny": ["Bash"]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/local/bin/my-bash-guard.sh"
          }
        ]
      }
    ]
  }
}